    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^7.0.5",
    "pg": "^8.13.1",
    "redis": "^5.6.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
