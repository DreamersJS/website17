  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "lint": "eslint .",
    "test": "cross-env NODE_ENV=test dotenv_config_path=.env.test node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "jest --watch",
    "test:db": "docker compose -f docker-compose.test.yml up -d",
    "test:migrate": "dotenv -e .env.test -- npx prisma migrate deploy --schema prisma/schema.prisma",
    "test:reset": "dotenv -e .env.test -- prisma migrate reset --force"
  },
